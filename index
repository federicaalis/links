<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Federica Alis | Official</title>
    <style>
        body { font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto; background-color: #000; color: #fff; margin: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; text-align: center; }
        .container { width: 90%; max-width: 400px; padding: 20px; }
        .profile-pic { width: 100px; height: 100px; border-radius: 50%; margin-bottom: 10px; object-fit: cover; border: 2px solid #333; }
        h1 { font-size: 22px; margin-bottom: 5px; }
        p.subtitle { color: #888; margin-bottom: 30px; font-size: 14px; }
        
        /* Stile tasti simili a marisa-bottone */
        .link-card { background: #1a1a1a; border: 1px solid #333; border-radius: 15px; padding: 15px; margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between; text-decoration: none; color: white; cursor: pointer; transition: 0.3s; }
        .link-card:hover { background: #222; }
        .link-info { display: flex; align-items: center; gap: 15px; }
        .icon { width: 30px; height: 30px; border-radius: 5px; }

        /* Pop-up di protezione (Lo scudo anti-ban) */
        .overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 100; flex-direction: column; align-items: center; justify-content: center; padding: 20px; box-sizing: border-box; }
        .warning-box { background: #111; border: 1px solid #333; padding: 30px; border-radius: 20px; max-width: 350px; }
        .warning-title { color: #ff3b30; font-weight: bold; font-size: 20px; margin-bottom: 15px; display: block; }
        .warning-text { color: #ccc; font-size: 14px; margin-bottom: 25px; display: block; }
        .btn-continue { background: #fff; color: #000; padding: 12px 30px; border-radius: 10px; text-decoration: none; font-weight: bold; display: inline-block; margin-bottom: 10px; width: 100%; box-sizing: border-box; }
        .btn-back { color: #888; text-decoration: none; font-size: 13px; }
    </style>
</head>
<body>

    <div class="container">
        <img src="photo_2026-03-05_20-23-03.jpg" class="profile-pic">
        <h1>Federica Alis</h1>
        <p class="subtitle">Model & Content creator</p>

        <div class="link-card" onclick="openShield('https://onlyfans.com/federicaalis?rec=524586367')">
            <div class="link-info">
                <img src="https://img.icons8.com/color/48/onlyfans.png" class="icon">
                <span>Exclusive Content</span>
            </div>
            <span>➔</span>
        </div>

        <div class="link-card" onclick="openShield('https://t.me/+MOxKm5jAldExMDFk')">
            <div class="link-info">
                <img src="https://img.icons8.com/color/48/telegram-app.png" class="icon">
                <span>Telegram</span>
            </div>
            <span>➔</span>
        </div>
    </div>

    <div id="shield" class="overlay">
        <div class="warning-box">
            <span class="warning-title">Contenuto sensibile</span>
            <span class="warning-text">Questo collegamento può portare a contenuti che potrebbero non essere appropriati per tutti i segmenti di pubblico.</span>
            <a id="target-link" href="#" class="btn-continue">Continua</a><br>
            <a href="#" class="btn-back" onclick="closeShield()">Torna indietro</a>
        </div>
    </div>

    <script>
        function openShield(link) {
            document.getElementById('target-link').href = link;
            document.getElementById('shield').style.display = 'flex';
        }
        function closeShield() {
            document.getElementById('shield').style.display = 'none';
        }
    </script>

</body>
</html>
