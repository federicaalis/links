<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Federica Alis | Links</title>
    <style>
        body {
            font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #000000;
            color: #ffffff;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }
        .container {
            width: 100%;
            max-width: 450px;
            text-align: center;
        }
        .profile-pic {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 12px;
        }
        h1 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 35px;
            letter-spacing: -0.5px;
        }
        /* Bottoni Stile Beacons */
        .link-card {
            background-color: #1a1a1a;
            color: #ffffff;
            text-decoration: none;
            display: block;
            padding: 20px;
            margin-bottom: 12px;
            border-radius: 12px;
            font-weight: 500;
            font-size: 16px;
            transition: 0.2s ease;
            border: 1px solid #333;
        }
        .link-card:active {
            transform: scale(0.98);
            background-color: #252525;
        }

        /* Scudo di protezione Anti-Ban */
        .overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.98);
            z-index: 1000;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            box-sizing: border-box;
        }
        .warning-box {
            background: #111;
            padding: 30px;
            border-radius: 24px;
            border: 1px solid #333;
            max-width: 340px;
            text-align: center;
        }
        .warning-title { color: #ff3b30; font-weight: 700; font-size: 19px; margin-bottom: 10px; display: block; }
        .btn-confirm {
            background: #fff; color: #000;
            padding: 14px; border-radius: 12px;
            text-decoration: none; font-weight: bold;
            display: block; margin-top: 25px;
        }
    </style>
</head>
<body>

    <div class="container">
        <img src="photo_2026-03-05_20-23-03.jpg" alt="Federica Alis" class="profile-pic">
        
        <h1>@federicaalis</h1>

        <a href="#" class="link-card" onclick="openShield('https://onlyfans.com/federicaalis?rec=524586367')">
            Exclusive Content 🔗
        </a>

        <a href="#" class="link-card" onclick="openShield('https://t.me/+MOxKm5jAldExMDFk')">
            Telegram 📢
        </a>
    </div>

    <div id="shield" class="overlay">
        <div class="warning-box">
            <span class="warning-title">Sensitive content</span>
            <p style="font-size: 14px; color: #888; line-height: 1.5;">This link may take you to content that may not be appropriate for all audiences.</p>
            <a id="target-link" href="#" class="btn-confirm">Continue</a>
            <a href="#" style="color: #555; font-size: 13px; margin-top: 20px; display: block; text-decoration: none;" onclick="closeShield()">Go back</a>
        </div>
    </div>

    <script>
        function openShield(link) {
            document.getElementById('target-link').href = link;
            document.getElementById('shield').style.display = 'flex';
        }
        function closeShield() {
            document.getElementById('shield').style.display = 'none';
        }
    </script>

</body>
</html>
